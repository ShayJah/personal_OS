generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  image     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  profile        Profile?
  projects       Project[]
  tasks          Task[]
  habits         Habit[]
  captures       Capture[]
  priorities     Priority[]
  calendarEvents CalendarEvent[]
  coachThreads   CoachThread[]
  reports        Report[]
  sharedLinks    SharedLink[]
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  timezone        String   @default("UTC")
  theme           String   @default("system")
  onboardingDone  Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  shareSettings ShareSettings?
}

model Project {
  id        String     @id @default(cuid())
  userId    String
  name      String
  description String?
  color     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([userId])
}

model Priority {
  id        String     @id @default(cuid())
  userId    String
  date      DateTime   @db.Date
  content   String
  order     Int
  completed Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, order])
  @@index([userId, date])
}

model Task {
  id          String     @id @default(cuid())
  userId      String
  projectId   String?
  title       String
  description String?
  dueDate     DateTime?
  completed   Boolean    @default(false)
  priority    Int?
  tags        String[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  calendarEvents CalendarEvent[]

  @@index([userId])
  @@index([projectId])
}

model CalendarEvent {
  id          String   @id @default(cuid())
  userId      String
  taskId      String?
  title       String
  description String?
  location    String?
  startAt     DateTime
  endAt       DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, startAt])
}

model Habit {
  id        String     @id @default(cuid())
  userId    String
  name      String
  frequency String     @default("daily")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs  HabitLog[]

  @@index([userId])
}

model HabitLog {
  id        String     @id @default(cuid())
  habitId   String
  userId    String
  date      DateTime   @db.Date
  completed Boolean    @default(false)
  createdAt DateTime   @default(now())

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([userId])
}

model Capture {
  id        String     @id @default(cuid())
  userId    String
  content   String
  type      String     @default("text")
  classified String?
  createdAt DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CoachThread {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages CoachMessage[]

  @@index([userId])
}

model CoachMessage {
  id        String   @id @default(cuid())
  threadId  String
  role      String
  content   String
  createdAt DateTime @default(now())

  thread CoachThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

model Report {
  id          String   @id @default(cuid())
  userId      String
  type        String
  periodStart DateTime @db.Date
  periodEnd   DateTime @db.Date
  content     String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, periodStart])
  @@index([userId])
}

model ShareSettings {
  id                 String   @id @default(cuid())
  profileId          String   @unique
  shareProgressPage  Boolean  @default(false)
  shareReports       Boolean  @default(false)
  shareTasks         Boolean  @default(false)
  shareHabits        Boolean  @default(false)
  shareHighlights    Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model SharedLink {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  type      String   // "progress", "report", "summary"
  target    String?  // For specific report IDs, etc.
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}
