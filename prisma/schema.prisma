generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  image     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  profile        Profile?
  projects       Project[]
  tasks          Task[]
  habits         Habit[]
  captures       Capture[]
  priorities     Priority[]
  calendarEvents CalendarEvent[]
  coachThreads   CoachThread[]
  reports        Report[]
  sharedLinks    SharedLink[]
  agentRuns      AgentRun[]
  notifications  Notification[]
  journalEntries JournalEntry[]
  goals          Goal[]
  metrics        Metric[]
  workouts       Workout[]
  businesses     Business[]
  businessCollaborations BusinessCollaborator[]
  contacts       Contact[]
  googleCalendarConnection GoogleCalendarConnection?
  hevyConnection HevyConnection?
  gmailConnection GmailConnection?
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  timezone        String   @default("UTC")
  theme           String   @default("system")
  onboardingDone  Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  shareSettings ShareSettings?
}

model Project {
  id        String     @id @default(cuid())
  userId    String
  name      String
  description String?
  color     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  searchVector Unsupported("tsvector")?

  @@index([userId])
}

model Priority {
  id        String     @id @default(cuid())
  userId    String
  date      DateTime   @db.Date
  content   String
  order     Int
  completed Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, order])
  @@index([userId, date])
}

model Task {
  id          String     @id @default(cuid())
  userId      String
  projectId   String?
  title       String
  description String?
  dueDate     DateTime?
  completed   Boolean    @default(false)
  priority    Int?
  tags        String[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  calendarEvents CalendarEvent[]

  searchVector Unsupported("tsvector")?

  @@index([userId])
  @@index([projectId])
}

model CalendarEvent {
  id            String   @id @default(cuid())
  userId        String
  taskId        String?
  title         String
  description   String?
  location      String?
  startAt       DateTime
  endAt         DateTime
  googleEventId String?  @unique
  syncedAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, startAt])
  @@index([googleEventId])
}

model GoogleCalendarConnection {
  id           String    @id @default(cuid())
  userId       String    @unique
  calendarId   String    @default("primary")
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scope        String
  connectedAt  DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GmailConnection {
  id           String    @id @default(cuid())
  userId       String    @unique
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scope        String
  connectedAt  DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HevyConnection {
  id          String   @id @default(cuid())
  userId      String   @unique
  apiKey      String
  connectedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Metric {
  id        String   @id @default(cuid())
  userId    String
  kind      String
  value     Decimal
  unit      String?
  date      DateTime @db.Date
  source    String   @default("manual")
  meta      Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, date, source])
  @@index([userId, kind, date])
}

model Workout {
  id            String   @id @default(cuid())
  userId        String
  hevyWorkoutId String   @unique
  title         String?
  startAt       DateTime
  endAt         DateTime
  volumeKg      Decimal
  exercises     Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startAt])
}

model Habit {
  id        String     @id @default(cuid())
  userId    String
  name      String
  frequency String     @default("daily")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs  HabitLog[]

  @@index([userId])
}

model HabitLog {
  id        String     @id @default(cuid())
  habitId   String
  userId    String
  date      DateTime   @db.Date
  completed Boolean    @default(false)
  createdAt DateTime   @default(now())

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([userId])
}

model Capture {
  id        String     @id @default(cuid())
  userId    String
  content   String
  type      String     @default("text")
  classified String?
  createdAt DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  searchVector Unsupported("tsvector")?

  @@index([userId])
}

model CoachThread {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages CoachMessage[]

  @@index([userId])
}

model CoachMessage {
  id        String   @id @default(cuid())
  threadId  String
  role      String
  content   String
  createdAt DateTime @default(now())

  thread CoachThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

model Report {
  id          String   @id @default(cuid())
  userId      String
  type        String
  periodStart DateTime @db.Date
  periodEnd   DateTime @db.Date
  content     String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, periodStart])
  @@index([userId])
}

model AgentRun {
  id         String    @id @default(cuid())
  userId     String
  agent      String
  trigger    String
  status     String    @default("running")
  output     Json?
  toolTrace  Json?
  costUsd    Decimal?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  kind      String
  title     String
  body      String?
  actionUrl String?
  payload   Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  body      String
  mood      Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model Goal {
  id           String   @id @default(cuid())
  userId       String
  horizon      String
  title        String
  why          String?
  area         String   @default("personal")
  targetValue  Decimal?
  currentValue Decimal?
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ShareSettings {
  id                 String   @id @default(cuid())
  profileId          String   @unique
  shareProgressPage  Boolean  @default(false)
  shareReports       Boolean  @default(false)
  shareTasks         Boolean  @default(false)
  shareHabits        Boolean  @default(false)
  shareHighlights    Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model SharedLink {
  id        String   @id @default(cuid())
  userId    String
  token       String   @unique
  type        String   // "progress", "report", "summary", "business"
  target      String?  // For specific report IDs, business IDs, etc.
  detailLevel String?  // "overview" | "pipeline" | "full" (business shares only)
  allowEdit   Boolean  @default(false)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Business {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  contextDoc  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  crmRecords    CrmRecord[]
  collaborators BusinessCollaborator[]

  @@index([userId])
}

model BusinessCollaborator {
  id         String   @id @default(cuid())
  businessId String
  userId     String
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([businessId])
  @@index([userId])
}

model Contact {
  id        String   @id @default(cuid())
  userId    String
  name      String
  email     String?
  phone     String?
  company   String?
  role      String?
  notes     String?
  createdAt DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  crmRecords CrmRecord[]

  @@index([userId])
}

model CrmRecord {
  id           String    @id @default(cuid())
  businessId   String
  contactId    String
  stage        String    @default("lead")
  value        Decimal?
  source       String?
  lastTouchAt  DateTime?
  nextAction   String?
  nextActionAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  business   Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  contact    Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  activities Activity[]
  drafts     EmailDraft[]

  @@index([businessId])
  @@index([contactId])
}

model Activity {
  id          String   @id @default(cuid())
  crmRecordId String
  kind        String
  body        String
  occurredAt  DateTime @default(now())

  crmRecord CrmRecord @relation(fields: [crmRecordId], references: [id], onDelete: Cascade)

  @@index([crmRecordId])
}

model EmailDraft {
  id            String   @id @default(cuid())
  crmRecordId   String
  channel       String   @default("email")
  subject       String?
  body          String
  researchNotes String?
  status        String   @default("pending")
  gmailDraftId  String?
  createdAt     DateTime @default(now())

  crmRecord CrmRecord @relation(fields: [crmRecordId], references: [id], onDelete: Cascade)

  @@index([crmRecordId])
}
