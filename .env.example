# Auth.js / NextAuth secret — generate with `openssl rand -base64 32`
AUTH_SECRET=

# GitHub OAuth app credentials (https://github.com/settings/developers)
# Homepage URL: your deployed URL (or http://localhost:3000 for dev)
# Callback URL: <homepage-url>/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth app credentials, used for Google Calendar sync and Gmail
# draft creation (same OAuth client — just add both redirect URIs below to
# it in Google Cloud Console, and enable the Gmail API for the project):
#   <homepage-url>/api/integrations/google-calendar/callback
#   <homepage-url>/api/integrations/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Shared secret Vercel Cron sends as `Authorization: Bearer <value>` when
# invoking scheduled routes under app/api/cron/*. Generate with
# `openssl rand -base64 32` and set the same value in Vercel's env vars.
CRON_SECRET=
